# Supabase (same project as frontend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# SmugMug API
SMUGMUG_API_KEY=your_api_key
SMUGMUG_API_SECRET=your_api_secret

# Optional tuning
# INDEX_CONCURRENCY=8       # parallel download streams
# INDEX_CPU_WORKERS=4       # face detection worker processes (default: cpu_count/2)
# FACE_DETECTOR=yunet       # yunet (fast) or retinaface (slower, more accurate)
# FACE_MAX_DIM=960          # downscale images to this max dimension
# FACE_MIN_PX=30            # skip faces smaller than this many pixels
