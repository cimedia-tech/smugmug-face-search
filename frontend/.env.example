# Supabase (get from: supabase.com → Project Settings → API Keys → Legacy tab)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # server-side only, never expose to browser

# SmugMug API (get from: account.smugmug.com → API Keys)
SMUGMUG_API_KEY=your_api_key
SMUGMUG_API_SECRET=your_api_secret

# URLs (update to production values when deploying to Vercel)
FRONTEND_URL=http://localhost:3000
CALLBACK_URL=http://localhost:3000/api/auth/callback
